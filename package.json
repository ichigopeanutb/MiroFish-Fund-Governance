{
  "name": "mirofish",
  "version": "0.1.0",
  "description": "MiroFish - 简洁通用的群体智能引擎，预测万物",
  "scripts": {
    "setup": "npm install && cd frontend && npm install",
    "setup:backend": "cd backend && uv sync",
    "setup:all": "npm run setup && npm run setup:backend",
    "dev": "concurrently --kill-others -n \"backend,frontend\" -c \"green,cyan\" \"npm run backend\" \"npm run frontend\"",
    "dev:stable": "python3 scripts/stable_launcher.py",
    "backend": "cd backend && FLASK_DEBUG=false FLASK_HOST=127.0.0.1 uv run python run.py",
    "frontend": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "business:smoke": "cd backend && uv run python ../scripts/business_governance_public_alpha_smoke.py",
    "business:example": "cd backend && uv run python ../scripts/business_governance_public_alpha_smoke.py --write-summary docs/examples/business-governance-alpha-summary.json",
    "business:quickstart": "npm run setup:all && npm run business:smoke"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "AGPL-3.0"
}
