# LLM API配置（支持 OpenAI SDK 格式的任意 LLM API）
# 推荐使用阿里百炼平台qwen-plus模型：https://bailian.console.aliyun.com/
# 注意消耗较大，可先进行小于40轮的模拟尝试
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== ZEP记忆图谱配置 =====
# 每月免费额度即可支撑简单使用：https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Business governance private beta gate（可选）=====
# 不要把真实试用密码提交到 repo；请在 .env 或部署环境中设置。
# 设置后，business-simulation API 会要求 access code。
BUSINESS_DEMO_ACCESS_CODE=replace_with_private_beta_access_code
# 如果没有使用 npm run dev:stable，而是直接 build/deploy 前端，也设置同一个值。
VITE_BUSINESS_DEMO_PASSWORD=replace_with_private_beta_access_code
# 多组试用密码 registry，默认在 private/ 下，已被 .gitignore 排除。
BUSINESS_DEMO_ACCESS_REGISTRY_PATH=private/business-demo-access-codes.json
# Owner-only 管理介面使用。不要提交真实 owner code。
BUSINESS_DEMO_OWNER_CODE=replace_with_owner_console_code

# ===== 加速 LLM 配置（可选）=====
# 注意如果不使用加速配置，env文件中就不要出现下面的配置项
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here
